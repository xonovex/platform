digraph SandboxCompose {
  rankdir=TB;
  splines=polyline;
  nodesep=0.5;
  ranksep=0.6;
  bgcolor="white";

  node [shape=box, style="rounded,filled", fontname="Inter,Helvetica,Arial", fontsize=11];
  edge [fontname="Inter,Helvetica,Arial", fontsize=9, color="#999999"];

  label="Docker Compose — Multi-Service Container Isolation";
  labelloc=t;
  fontsize=14;
  fontname="Inter,Helvetica,Arial";
  fontcolor="#0277bd";

  subgraph cluster_host {
    label="Host OS";
    style="rounded,filled";
    fillcolor="#e1f5fe";
    color="#4fc3f7";

    dockerd [label="Docker Daemon", fillcolor="#81d4fa", color="#0277bd", shape=hexagon];

    subgraph cluster_compose {
      label="Compose Stack";
      style="rounded,bold,filled";
      fillcolor="#b3e5fc";
      color="#0277bd";
      penwidth=2;

      subgraph cluster_svc1 {
        label="AI Agent Service";
        style="rounded,filled";
        fillcolor="#e0f7fa";
        color="#00838f";
        fontsize=10;

        agent [label="AI Agent", fillcolor="#4dd0e1", color="#00838f", shape=ellipse];
      }

      subgraph cluster_svc2 {
        label="Supporting Services";
        style="rounded,dashed,filled";
        fillcolor="#e0f7fa";
        color="#00838f";
        fontsize=10;

        tools [label="DB / Tools / LSP\n...", fillcolor="#b2ebf2", fontsize=9];
      }

      net [label="Isolated Bridge Network", fillcolor="#b2ebf2", fontsize=9, shape=tab];
    }

    kernel [label="Shared Kernel", fillcolor="#039be5", color="#0277bd", shape=cylinder, fontcolor=white];
  }

  hw [label="Hardware", fillcolor="#0277bd", fontcolor=white, color="#01579b", shape=box3d];

  dockerd -> agent [label="create"];
  agent -> net;
  tools -> net [style=dashed];
  agent -> kernel [label="filtered\nsyscalls"];
  kernel -> hw;
}

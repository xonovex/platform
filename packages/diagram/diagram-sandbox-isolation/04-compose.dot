digraph Compose {
  rankdir=TB;
  splines=false;
  nodesep=0.3;
  ranksep=0.5;
  bgcolor="white";
  margin=0.3;

  node [shape=box, style="filled", fontname="Helvetica", fontsize=12, width=2.2, height=0.5];
  edge [fontname="Helvetica", fontsize=9, color="#666666"];

  label="Docker Compose — Multi-Service Container Isolation";
  labelloc=t;
  fontsize=14;
  fontname="Helvetica-Bold";

  subgraph {
    rank=same;
    agent [label="AI Agent", fillcolor="#4FC3F7"];
    services [label="DB / Tools / LSP", fillcolor="#B2EBF2", style="filled,dashed"];
  }

  network [label="Isolated Bridge Network", fillcolor="#E0F7FA"];
  container [label="Container isolation\n(namespaces, cgroups, seccomp)", fillcolor="#BBDEFB", fontsize=10];

  sb_label [label="- - - - sandbox - - - -", shape=plaintext, fontsize=10, fontcolor="#C62828"];

  kernel [label="Host Kernel (shared)", fillcolor="#FF8A65", fontcolor=white];
  hw [label="Hardware", fillcolor="#78909C", fontcolor=white];

  agent -> network;
  services -> network;
  network -> container;
  container -> sb_label [style=invis];
  sb_label -> kernel [style=invis];
  container -> kernel [label="  filtered syscalls"];
  kernel -> hw;
}

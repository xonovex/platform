digraph SandboxOverview {
  rankdir=LR;
  splines=ortho;
  nodesep=0.5;
  ranksep=1.2;
  bgcolor="white";

  node [shape=box, style="rounded,filled", fontname="Inter,Helvetica,Arial", fontsize=11];
  edge [fontname="Inter,Helvetica,Arial", fontsize=9, color="#90a4ae"];

  label="AI Agent Sandbox Isolation Spectrum";
  labelloc=t;
  fontsize=16;
  fontname="Inter,Helvetica,Arial";
  fontcolor="#263238";

  agent [label="AI Agent", shape=ellipse, fillcolor="#e3f2fd", color="#1565c0", penwidth=2, fontsize=12];

  none [label="None", fillcolor="#ffcdd2", color="#c62828"];
  bwrap [label="Bubblewrap", fillcolor="#c8e6c9", color="#2e7d32"];
  docker [label="Docker", fillcolor="#bbdefb", color="#1565c0"];
  compose [label="Docker\nCompose", fillcolor="#b3e5fc", color="#0277bd"];
  nix [label="Nix +\nBubblewrap", fillcolor="#d1c4e9", color="#4527a0"];
  gvisor [label="gVisor", fillcolor="#fff9c4", color="#f9a825"];
  kata [label="Kata\nContainers", fillcolor="#ffe0b2", color="#e65100"];
  coco [label="Confidential\nContainers", fillcolor="#ffccbc", color="#bf360c"];

  // Scale
  s1 [label="No\nIsolation", shape=plaintext, fontcolor="#c62828", fontsize=9];
  s2 [label="Namespace", shape=plaintext, fontcolor="#2e7d32", fontsize=9];
  s3 [label="Container", shape=plaintext, fontcolor="#1565c0", fontsize=9];
  s4 [label="Syscall\nFilter", shape=plaintext, fontcolor="#f9a825", fontsize=9];
  s5 [label="VM", shape=plaintext, fontcolor="#e65100", fontsize=9];
  s6 [label="Hardware\nTEE", shape=plaintext, fontcolor="#bf360c", fontsize=9];

  agent -> none;
  agent -> bwrap;
  agent -> docker;
  agent -> compose;
  agent -> nix;
  agent -> gvisor;
  agent -> kata;
  agent -> coco;

  s1 -> s2 -> s3 -> s4 -> s5 -> s6 [style=bold, color="#b0bec5", arrowhead=vee];

  none -> s1 [style=dotted, constraint=false, color="#e0e0e0"];
  bwrap -> s2 [style=dotted, constraint=false, color="#e0e0e0"];
  nix -> s2 [style=dotted, constraint=false, color="#e0e0e0"];
  docker -> s3 [style=dotted, constraint=false, color="#e0e0e0"];
  compose -> s3 [style=dotted, constraint=false, color="#e0e0e0"];
  gvisor -> s4 [style=dotted, constraint=false, color="#e0e0e0"];
  kata -> s5 [style=dotted, constraint=false, color="#e0e0e0"];
  coco -> s6 [style=dotted, constraint=false, color="#e0e0e0"];
}

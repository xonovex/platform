digraph Overview {
  rankdir=TB;
  splines=false;
  nodesep=0.4;
  ranksep=0.4;
  bgcolor="white";
  margin=0.3;

  node [shape=box, style="filled", fontname="Helvetica", fontsize=11, width=1.4, height=0.4];
  edge [fontname="Helvetica", fontsize=9];

  label="AI Agent Sandbox Isolation Spectrum";
  labelloc=t;
  fontsize=14;
  fontname="Helvetica-Bold";

  // Column headers
  subgraph {
    rank=same;
    h1 [label="None", shape=plaintext, fontsize=10, fontname="Helvetica-Bold"];
    h2 [label="Bubblewrap", shape=plaintext, fontsize=10, fontname="Helvetica-Bold"];
    h3 [label="Docker", shape=plaintext, fontsize=10, fontname="Helvetica-Bold"];
    h4 [label="Nix + bwrap", shape=plaintext, fontsize=10, fontname="Helvetica-Bold"];
    h5 [label="gVisor", shape=plaintext, fontsize=10, fontname="Helvetica-Bold"];
    h6 [label="Kata / CoCo", shape=plaintext, fontsize=10, fontname="Helvetica-Bold"];
  }

  // Application layer
  subgraph {
    rank=same;
    a1 [label="AI Agent", fillcolor="#4FC3F7"];
    a2 [label="AI Agent", fillcolor="#4FC3F7"];
    a3 [label="AI Agent", fillcolor="#4FC3F7"];
    a4 [label="AI Agent", fillcolor="#4FC3F7"];
    a5 [label="AI Agent", fillcolor="#4FC3F7"];
    a6 [label="AI Agent", fillcolor="#4FC3F7"];
  }

  // Sandbox / isolation layer
  subgraph {
    rank=same;
    s1 [label="(no sandbox)", fillcolor="#FFCDD2", style="filled,dashed"];
    s2 [label="Namespaces\n+ bind mounts", fillcolor="#C8E6C9"];
    s3 [label="Namespaces\ncgroups, seccomp", fillcolor="#BBDEFB"];
    s4 [label="Namespaces\n+ /nix/store (ro)", fillcolor="#D1C4E9"];
    s5 [label="Sentry\n(user-space kernel)", fillcolor="#FFF9C4"];
    s6 [label="Guest Kernel\n(separate VM)", fillcolor="#FFE0B2"];
  }

  // Kernel layer
  subgraph {
    rank=same;
    k1 [label="Host Kernel", fillcolor="#FF8A65", fontcolor=white];
    k2 [label="Host Kernel", fillcolor="#FF8A65", fontcolor=white];
    k3 [label="Host Kernel", fillcolor="#FF8A65", fontcolor=white];
    k4 [label="Host Kernel", fillcolor="#FF8A65", fontcolor=white];
    k5 [label="Host Kernel\n(~60 syscalls)", fillcolor="#FF8A65", fontcolor=white];
    k6 [label="Hypervisor\n+ Host Kernel", fillcolor="#FF8A65", fontcolor=white];
  }

  // Hardware
  subgraph {
    rank=same;
    hw1 [label="Hardware", fillcolor="#78909C", fontcolor=white];
    hw2 [label="Hardware", fillcolor="#78909C", fontcolor=white];
    hw3 [label="Hardware", fillcolor="#78909C", fontcolor=white];
    hw4 [label="Hardware", fillcolor="#78909C", fontcolor=white];
    hw5 [label="Hardware", fillcolor="#78909C", fontcolor=white];
    hw6 [label="Hardware\n(VT-x / TEE)", fillcolor="#78909C", fontcolor=white];
  }

  // Vertical flows
  h1 -> a1 [style=invis];
  a1 -> s1 [style=dashed, color="#C62828", label="  no\n  barrier", fontcolor="#C62828"];
  s1 -> k1;
  k1 -> hw1;

  h2 -> a2 [style=invis];
  a2 -> s2;
  s2 -> k2 [label="  all\n  syscalls"];
  k2 -> hw2;

  h3 -> a3 [style=invis];
  a3 -> s3;
  s3 -> k3 [label="  filtered\n  syscalls"];
  k3 -> hw3;

  h4 -> a4 [style=invis];
  a4 -> s4;
  s4 -> k4 [label="  all\n  syscalls"];
  k4 -> hw4;

  h5 -> a5 [style=invis];
  a5 -> s5;
  s5 -> k5 [label="  minimal\n  surface", style=dashed];
  k5 -> hw5;

  h6 -> a6 [style=invis];
  a6 -> s6;
  s6 -> k6 [label="  KVM", style=dashed];
  k6 -> hw6;

  // Invisible horizontal ordering
  h1 -> h2 -> h3 -> h4 -> h5 -> h6 [style=invis];
  a1 -> a2 -> a3 -> a4 -> a5 -> a6 [style=invis];
  s1 -> s2 -> s3 -> s4 -> s5 -> s6 [style=invis];
  k1 -> k2 -> k3 -> k4 -> k5 -> k6 [style=invis];
  hw1 -> hw2 -> hw3 -> hw4 -> hw5 -> hw6 [style=invis];

  // Isolation arrow
  arrow_label [label="Isolation strength →", shape=plaintext, fontsize=10, fontcolor="#546E7A"];
  hw1 -> arrow_label [style=invis];
}

digraph SandboxKata {
  rankdir=TB;
  splines=polyline;
  nodesep=0.5;
  ranksep=0.6;
  bgcolor="white";

  node [shape=box, style="rounded,filled", fontname="Inter,Helvetica,Arial", fontsize=11];
  edge [fontname="Inter,Helvetica,Arial", fontsize=9, color="#999999"];

  label="Kata Containers — Lightweight VM Isolation";
  labelloc=t;
  fontsize=14;
  fontname="Inter,Helvetica,Arial";
  fontcolor="#e65100";

  subgraph cluster_host {
    label="Host";
    style="rounded,filled";
    fillcolor="#fff3e0";
    color="#ffcc80";

    subgraph cluster_vm {
      label="Lightweight VM";
      style="rounded,bold,filled";
      fillcolor="#ffe0b2";
      color="#e65100";
      penwidth=3;

      guest_kernel [label="Guest Kernel\n(separate)", fillcolor="#ff9100", color="#e65100", shape=cylinder, fontcolor=white];
      agent [label="AI Agent", fillcolor="#ffcc80", color="#e65100", shape=ellipse];
    }

    hypervisor [label="QEMU /\nCloud-Hypervisor", fillcolor="#ff6d00", color="#e65100", shape=box3d, fontcolor=white];
    host_kernel [label="Host Kernel", fillcolor="#e65100", color="#bf360c", shape=cylinder, fontcolor=white];
  }

  hw [label="Hardware\n(VT-x / AMD-V)", fillcolor="#bf360c", fontcolor=white, color="#7f2400", shape=box3d];

  agent -> guest_kernel [label="syscalls\n(guest only)"];
  hypervisor -> guest_kernel [label="boot VM"];
  hypervisor -> host_kernel [label="KVM"];
  host_kernel -> hw;
}

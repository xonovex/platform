digraph SandboxBwrap {
  rankdir=TB;
  splines=polyline;
  nodesep=0.5;
  ranksep=0.6;
  bgcolor="white";

  node [shape=box, style="rounded,filled", fontname="Inter,Helvetica,Arial", fontsize=11];
  edge [fontname="Inter,Helvetica,Arial", fontsize=9, color="#999999"];

  label="Bubblewrap — Linux Namespace Isolation";
  labelloc=t;
  fontsize=14;
  fontname="Inter,Helvetica,Arial";
  fontcolor="#2e7d32";

  subgraph cluster_host {
    label="Host OS";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    color="#66bb6a";

    subgraph cluster_sandbox {
      label="bwrap sandbox";
      style="rounded,bold,filled";
      fillcolor="#c8e6c9";
      color="#2e7d32";
      penwidth=2;

      agent [label="AI Agent", fillcolor="#81c784", color="#2e7d32", shape=ellipse];
      ns [label="PID | IPC | UTS | cgroup\n(unshared)", fillcolor="#a5d6a7", fontsize=9];
      mounts [label="/usr,/lib,/bin (ro)\nworkdir (rw) | /tmp (tmpfs)", fillcolor="#a5d6a7", fontsize=9, shape=folder];
    }

    kernel [label="Shared Kernel", fillcolor="#66bb6a", color="#2e7d32", shape=cylinder, fontcolor=white];
  }

  hw [label="Hardware", fillcolor="#43a047", fontcolor=white, color="#2e7d32", shape=box3d];

  agent -> ns [style=dotted, arrowhead=none];
  agent -> mounts [label="bind mounts"];
  agent -> kernel [label="syscalls\n(shared)"];
  kernel -> hw;
}

digraph SandboxDocker {
  rankdir=TB;
  splines=polyline;
  nodesep=0.5;
  ranksep=0.6;
  bgcolor="white";

  node [shape=box, style="rounded,filled", fontname="Inter,Helvetica,Arial", fontsize=11];
  edge [fontname="Inter,Helvetica,Arial", fontsize=9, color="#999999"];

  label="Docker — Container Isolation";
  labelloc=t;
  fontsize=14;
  fontname="Inter,Helvetica,Arial";
  fontcolor="#1565c0";

  subgraph cluster_host {
    label="Host OS";
    style="rounded,filled";
    fillcolor="#e3f2fd";
    color="#64b5f6";

    dockerd [label="Docker Daemon", fillcolor="#90caf9", color="#1565c0", shape=hexagon];

    subgraph cluster_container {
      label="Container (runc)";
      style="rounded,bold,filled";
      fillcolor="#bbdefb";
      color="#1565c0";
      penwidth=2;

      agent [label="AI Agent", fillcolor="#42a5f5", color="#1565c0", shape=ellipse, fontcolor=white];
      ns [label="PID | Mount | UTS\nIPC | Net | User", fillcolor="#90caf9", fontsize=9];
      cgroups [label="cgroups\n(CPU, memory, I/O)", fillcolor="#90caf9", fontsize=9];
      seccomp [label="seccomp\n(syscall filter)", fillcolor="#90caf9", fontsize=9];
      fs [label="Image FS (layered)\n+ volume mounts", fillcolor="#90caf9", fontsize=9, shape=folder];
    }

    kernel [label="Shared Kernel", fillcolor="#1e88e5", color="#1565c0", shape=cylinder, fontcolor=white];
  }

  hw [label="Hardware", fillcolor="#1565c0", fontcolor=white, color="#0d47a1", shape=box3d];

  dockerd -> agent [label="create"];
  agent -> ns [style=dotted, arrowhead=none];
  agent -> seccomp [style=dotted, arrowhead=none];
  agent -> fs;
  agent -> kernel [label="filtered\nsyscalls"];
  kernel -> hw;
}

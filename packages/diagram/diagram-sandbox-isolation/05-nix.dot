digraph Nix {
  rankdir=TB;
  splines=false;
  nodesep=0.3;
  ranksep=0.5;
  bgcolor="white";
  margin=0.3;

  node [shape=box, style="filled", fontname="Helvetica", fontsize=12, width=3, height=0.5];
  edge [fontname="Helvetica", fontsize=9, color="#666666"];

  label="Nix + Bubblewrap — Reproducible Sandboxed Isolation";
  labelloc=t;
  fontsize=14;
  fontname="Helvetica-Bold";

  agent [label="AI Agent", fillcolor="#4FC3F7"];
  env [label="/env (from nix-build, read-only)", fillcolor="#D1C4E9"];
  store [label="/nix/store (immutable, content-addressed)", fillcolor="#CE93D8", fontcolor=white, fontsize=10];
  ns [label="PID | IPC | UTS | cgroup | net namespaces", fillcolor="#B39DDB", fontsize=10];

  sb_label [label="- - - - sandbox - - - -", shape=plaintext, fontsize=10, fontcolor="#C62828"];

  kernel [label="Host Kernel (shared)", fillcolor="#FF8A65", fontcolor=white];
  hw [label="Hardware", fillcolor="#78909C", fontcolor=white];

  agent -> env [label="  binaries from /env/bin"];
  env -> store;
  store -> ns;
  ns -> sb_label [style=invis];
  sb_label -> kernel [style=invis];
  ns -> kernel [label="  all syscalls (shared kernel)"];
  kernel -> hw;
}

digraph SandboxNix {
  rankdir=TB;
  splines=polyline;
  nodesep=0.5;
  ranksep=0.6;
  bgcolor="white";

  node [shape=box, style="rounded,filled", fontname="Inter,Helvetica,Arial", fontsize=11];
  edge [fontname="Inter,Helvetica,Arial", fontsize=9, color="#999999"];

  label="Nix + Bubblewrap — Reproducible Sandboxed Isolation";
  labelloc=t;
  fontsize=14;
  fontname="Inter,Helvetica,Arial";
  fontcolor="#4527a0";

  subgraph cluster_host {
    label="Host OS";
    style="rounded,filled";
    fillcolor="#ede7f6";
    color="#b39ddb";

    nix_build [label="nix-build", fillcolor="#b39ddb", color="#4527a0", shape=hexagon];
    nix_store [label="/nix/store\n(immutable)", fillcolor="#ce93d8", color="#7b1fa2", shape=cylinder];

    subgraph cluster_sandbox {
      label="bwrap sandbox";
      style="rounded,bold,filled";
      fillcolor="#d1c4e9";
      color="#4527a0";
      penwidth=2;

      agent [label="AI Agent", fillcolor="#ab47bc", color="#6a1b9a", shape=ellipse, fontcolor=white];
      ns [label="PID | IPC | UTS | cgroup\n+ optional net isolation", fillcolor="#ce93d8", fontsize=9];
      mounts [label="/env (ro, from nix-build)\n/nix/store (ro)\nworkdir (rw)", fillcolor="#ce93d8", fontsize=9, shape=folder];
    }

    kernel [label="Shared Kernel", fillcolor="#7e57c2", color="#4527a0", shape=cylinder, fontcolor=white];
  }

  hw [label="Hardware", fillcolor="#4527a0", fontcolor=white, color="#311b92", shape=box3d];

  nix_build -> nix_store [label="build"];
  nix_store -> mounts [label="mount ro", style=dashed];
  agent -> ns [style=dotted, arrowhead=none];
  agent -> mounts [label="reproducible\nbinaries"];
  agent -> kernel [label="syscalls\n(shared)"];
  kernel -> hw;
}

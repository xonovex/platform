{
  "extends": "@xonovex/ts-config-build",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@xonovex/vitest-config-base": ["../vitest-config-base/src/index.ts"],
      "@xonovex/vitest-config-base/*": ["../vitest-config-base/src/*"],
      "@xonovex/eslint-config-base": ["../eslint-config-base/src/index.ts"],
      "@xonovex/eslint-config-base/*": ["../eslint-config-base/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist"],
  "references": [
    {
      "path": "../eslint-config-base"
    },
    {
      "path": "../vitest-config-base"
    }
  ]
}

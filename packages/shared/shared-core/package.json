{
  "name": "@xonovex/core",
  "version": "0.1.22",
  "description": "Core library for Xonovex TypeScript scripts (Node.js)",
  "type": "module",
  "license": "MIT",
  "author": "Xonovex",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xonovex/platform.git",
    "directory": "packages/shared/shared-core"
  },
  "bugs": {
    "url": "https://github.com/xonovex/platform/issues"
  },
  "homepage": "https://github.com/xonovex/platform/tree/main/packages/shared/shared-core#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/src/index.js",
    "./*": "./dist/src/*.js"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@xonovex/eslint-config-cli": "0.1.22",
    "@xonovex/ts-config-cli": "0.1.22",
    "@xonovex/vitest-config-node": "0.1.22",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "xonovex",
    "shared",
    "core"
  ]
}

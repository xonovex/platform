{
  "name": "xonovex-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/asset/*",
    "packages/diagram/*",
    "packages/skill/*",
    "packages/command/*",
    "packages/config/*",
    "packages/agent/*",
    "packages/shared/*",
    "packages/script/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@moonrepo/cli": "2.3.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/eslint": "9.6.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-istanbul": "4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "dependency-cruiser": "18.0.0",
    "eslint": "^10.6.0",
    "gitlab-ci-local": "^4.73.0",
    "jiti": "^2.7.0",
    "jsdom": "29.1.1",
    "knip": "6.23.0",
    "npm-check-updates": "22.2.9",
    "prettier": "^3.9.4",
    "quicktype": "23.2.6",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "syncpack": "15.3.2",
    "tsx": "^4.22.4",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "deps:check": "npm-check-updates --workspaces --dep prod,dev,optional",
    "deps:update": "npm-check-updates --workspaces -u --dep prod,dev,optional",
    "nix:shell": "nix --extra-experimental-features 'nix-command flakes' develop",
    "nix:lock": "nix --extra-experimental-features 'nix-command flakes' flake lock",
    "ci:github": "act push -W .github/workflows/ci.yml --input dry_run=true",
    "ci:gitlab": "gitlab-ci-local --file .gitlab/ci.yml --variable DRY_RUN=true",
    "moon": "moon",
    "build": "moon run :build",
    "test": "moon run :test",
    "lint": "moon run :lint",
    "lint:fix": "moon run :lint:fix",
    "fmt": "moon run :fmt",
    "fmt:check": "moon run :fmt:check",
    "typecheck": "moon run :typecheck",
    "coverage": "moon run :coverage",
    "dev": "moon run :dev",
    "clean": "moon run :clean",
    "check:all": "moon run :lint :typecheck",
    "check:fast": "moon run :lint:fix :typecheck --concurrency=4",
    "check:affected": "moon run :lint:fix :typecheck :test :build :fmt --affected --concurrency=4",
    "ci": "moon ci",
    "sync:hooks": "moon sync hooks",
    "prepare": "npm run sync:hooks"
  },
  "packageManager": "npm@11.10.0"
}

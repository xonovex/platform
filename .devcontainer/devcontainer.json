{
  "name": "Xonovex Secure Coding Agent",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/xonovex-platform",

  "remoteUser": "vscode",
  "containerUser": "vscode",

  "mounts": [
    "source=xonovex-npm-cache,target=/home/vscode/.npm,type=volume",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind"
  ],

  "containerEnv": {
    "EDITOR": "code --wait",
    "DOCKER_CLI_HINTS": "false",
    "HTTP_PROXY": "http://proxy:3128",
    "HTTPS_PROXY": "http://proxy:3128",
    "NO_PROXY": "localhost,127.0.0.1"
  },

  "remoteEnv": {
    "SSH_AUTH_SOCK": "",
    "GPG_AGENT_INFO": "",
    "GNUPGHOME": "",
    "VSCODE_IPC_HOOK_CLI": "",
    "VSCODE_GIT_IPC_HANDLE": ""
  },

  "postAttachCommand": "bash -c '. /usr/local/bin/harden-ipc.sh'",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "dev.containers.copyGitConfig": false,
        "editor.formatOnSave": true
      }
    }
  }
}

# =============================================================================
# Developer-Local Configuration (copy to .env, which is gitignored)
#
# These settings activate optional features defined in the committed
# docker-compose.yml and allowed-ports.conf.
# Developers can only enable centrally approved features — they cannot
# add arbitrary capabilities, packages, or port forwards without a PR.
# =============================================================================

# Compose profiles — activate optional services and port relays.
# Comma-separated list matching profiles in allowed-ports.conf.
# Available profiles: android
# COMPOSE_PROFILES=android
